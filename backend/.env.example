# Application environment
NODE_ENV=production
PORT=3001

# Database connection
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name

# Authentication
JWT_SECRET=your_jwt_secret_key_here

# Default admin account (created during setup)
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=strong_admin_password
SUPERADMIN_NAME=System Administrator

# Cloudinary file storage (used for uploads like receipts or KYC files)
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Frontend URL for redirects and email links
FRONTEND_URL=http://localhost:5173

# Email configuration for notifications
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_email_app_password